# Copy this file to .env and fill in the values.

# --- Runtime (the server) -------------------------------------------------
# Auth is per-user: users sign up (name / email / password) and receive a personal
# access token, stored in a SQLite file. The WebSocket `init` handshake must present
# a valid user token or the connection is rejected (close 4001). There is no shared
# SERVER_ACCESS_TOKEN anymore.
#
# Where the user-account DB lives. Defaults to <repo>/data/users.db; in Docker it is a
# volume-mounted path shared by all replicas. Created automatically on first boot.
USERS_DB_PATH=data/users.db

LOG_LEVEL=INFO

# --- LLM / search keys and KB docs are NOT read by the server -------------
# The agent's OpenAI/Tavily keys, model names, AND the knowledge-base documents are
# supplied by each CLIENT in the `init`/`documents` handshake — never from the
# server's environment. Configure them on the client side (see clients/cli_client.py).
