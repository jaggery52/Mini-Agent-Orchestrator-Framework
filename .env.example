# Copy this file to .env and fill in the values.

# --- Runtime (the server) -------------------------------------------------
# The ONLY secret the running server needs. Clients must present this token in
# the WebSocket `init` handshake or the connection is rejected (close 4001).
SERVER_ACCESS_TOKEN=choose-a-long-random-token

LOG_LEVEL=INFO
FORCE_REINDEX=false                # Set true to force a RAG re-index (rarely needed at runtime)

# --- LLM / search keys are NOT read by the server -------------------------
# The agent's OpenAI/Tavily keys and model names are supplied by each CLIENT in
# the `init` handshake — never from the server's environment. Configure them on
# the client side (see clients/cli_client.py) instead.

# --- Build-time only ------------------------------------------------------
# The embedding key used to index the knowledge base into the image is passed as
# a Docker BUILD secret (./openai_key.txt), NOT a runtime env var. In CI/CD this
# becomes a GitHub Actions secret. It never lands in the running image.
#   echo "$OPENAI_API_KEY" > openai_key.txt
#   DOCKER_BUILDKIT=1 docker compose build
